# ==============================================
# CHARTERBUS FRONTEND - ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.local and fill in the values

# ==============================================
# API CONFIGURATION
# ==============================================
# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ==============================================
# SITE CONFIGURATION
# ==============================================
# Your live site URL (for SEO/Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.charterbus.com

# ==============================================
# BUSINESS CONFIGURATION
# ==============================================
# These values are used throughout the site
NEXT_PUBLIC_BUSINESS_NAME=CharterBus
NEXT_PUBLIC_BUSINESS_LEGAL_NAME=CharterBus LLC
NEXT_PUBLIC_BUSINESS_TAGLINE=The nation's leading provider of premium charter bus rentals
NEXT_PUBLIC_BUSINESS_DESCRIPTION=Book affordable charter buses for corporate events, weddings, and airport transfers. Safe, reliable & nationwide service.
NEXT_PUBLIC_LOGO_URL=/logo.png
NEXT_PUBLIC_BUSINESS_PHONE=+1-800-555-0199
NEXT_PUBLIC_BUSINESS_EMAIL=support@charterbus.com

# Address
NEXT_PUBLIC_BUSINESS_STREET=123 Main Street
NEXT_PUBLIC_BUSINESS_CITY=Chicago
NEXT_PUBLIC_BUSINESS_REGION=IL
NEXT_PUBLIC_BUSINESS_POSTAL_CODE=60601
NEXT_PUBLIC_BUSINESS_COUNTRY=US

# Geo coordinates
NEXT_PUBLIC_GEO_LATITUDE=41.8781
NEXT_PUBLIC_GEO_LONGITUDE=-87.6298

# Price range indicator ($, $$, $$$)
NEXT_PUBLIC_PRICE_RANGE=$$

# Social media URLs
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/charterbus
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/charterbus

# ==============================================
# GOOGLE VERIFICATION
# ==============================================
# Get this from Google Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# ==============================================
# LOCATION SERVICES
# ==============================================
# Get this from https://locationiq.com
NEXT_PUBLIC_LOCATIONIQ_KEY=your-locationiq-api-key

# ==============================================
# AUTH PROVIDER (if using NextAuth)
# ==============================================
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret
