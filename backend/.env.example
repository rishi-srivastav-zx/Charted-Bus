# ==============================================
# CHARTERBUS BACKEND - ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and fill in the values

# ==============================================
# SERVER CONFIGURATION
# ==============================================
NODE_ENV=development
PORT=3001




# ==============================================
# DATABASE
# ==============================================
MONGO_URI=mongodb://localhost:27017/charterbus

# ==============================================
# JWT AUTHENTICATION
# ==============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRE=7d

# Super Admin Setup Key (used to create initial superadmin)
SUPERADMIN_SETUP_KEY=your-superadmin-setup-key

# ==============================================
# EMAIL / SMTP
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email sender address
FROM_EMAIL=support@charterbus.com

# Dispatch/Lead notification email
DISPATCH_EMAIL=dispatch@charterbus.com

# ==============================================
# CLOUDINARY (Image/Video Storage)
# ==============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ==============================================
# LOCATION IQ (Address Autocomplete)
# ==============================================
LOCATIONIQ_API_KEY=your-locationiq-key
